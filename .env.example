# DevAgent Configuration

# Task provider: jira | yandex_tracker | linear
TASK_PROVIDER=yandex_tracker

# Code provider: github | arcanum | gitlab
CODE_PROVIDER=github

# Doc provider: notion | confluence | yandex_wiki
DOC_PROVIDER=notion

# LLM Configuration
LLM_STRONG_MODEL=claude-sonnet-4-20250514
LLM_FAST_MODEL=claude-haiku-4-20250414
ANTHROPIC_API_KEY=

# Optional: Ollama for local LLM
# LLM_FAST_MODEL=ollama/llama3
# OLLAMA_BASE_URL=http://localhost:11434

# Security
USE_EXTERNAL_LLM=true

# MCP Servers (optional) — auto-discover tools from MCP-compatible servers
# Preferred: use ~/.devagent/mcp_servers.yaml (see README for format)
# Fallback: MCP_SERVERS env variable
# Format: name:command:arg1,arg2  (separated by ';')
# Examples:
# MCP_SERVERS=tracker:npx:-y,@modelcontextprotocol/server-tracker
# MCP_SERVERS=github:npx:-y,@modelcontextprotocol/server-github;wiki:python:wiki_server.py

# Observability — set any of these to enable tracing
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=devagent
LOGFIRE_TOKEN=
